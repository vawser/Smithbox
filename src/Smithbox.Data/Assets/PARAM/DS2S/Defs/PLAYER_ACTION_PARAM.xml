            <DisplayName>乳酸加算角度[deg]</DisplayName>
            <Description>旋回攻撃時に乳酸増加倍率が適用される最低角度[度]</Description>
            <DisplayFormat>%.2f</DisplayFormat>
            <EditFlags>Wrap</EditFlags>
            <Maximum>180</Maximum>
            <Increment>0.5</Increment>
            <SortID>10</SortID>
        </Field>
        <Field Def="f32 fDecreaseDistressOnGuard = 5,000">
            <DisplayName>乳酸防衛減少値[ng]</DisplayName>
            <Description>防御「成功時」に乳酸が減少する量[ナノグラム]</Description>
            <DisplayFormat>%.2f</DisplayFormat>
            <EditFlags>Wrap</EditFlags>
            <Maximum>10000</Maximum>
            <Increment>1</Increment>
            <SortID>11</SortID>
        </Field>
    </Fields>
</PARAMDEF>
