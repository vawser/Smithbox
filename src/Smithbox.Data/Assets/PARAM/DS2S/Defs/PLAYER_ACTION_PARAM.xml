    <BigEndian>true</BigEndian>
    <Unicode>true</Unicode>
    <FormatVersion>104</FormatVersion>
    <Fields>
        <Field Def="f32 fMaxAdrenaline = 10,000">
            <DisplayName>最大アドレナリン総量[ng]</DisplayName>
            <Description>保持可能なアドレナリンの最大量[ナノグラム]</Description>
            <DisplayFormat>%.2f</DisplayFormat>
            <EditFlags>Wrap</EditFlags>
            <Maximum>10000</Maximum>
            <Increment>1</Increment>
            <SortID>1</SortID>
        </Field>
        <Field Def="f32 fDecreaseAderanalinePerSec = 100">
            <DisplayName>アドレナリン減少量[ng/s]</DisplayName>
            <Description>1秒当たりのアドレナリン減少量[ナノグラム/秒]</Description>
            <DisplayFormat>%.2f</DisplayFormat>
            <EditFlags>Wrap</EditFlags>
            <Maximum>10000</Maximum>
            <Increment>1</Increment>
            <SortID>2</SortID>
        </Field>
        <Field Def="f32 fAdrenalineCoolTime = 10">
            <DisplayName>アドレナリンクールタイム[sec]</DisplayName>
            <Description>アドレナリンによる加速処理終了時間[秒]</Description>
            <DisplayFormat>%.2f</DisplayFormat>
            <EditFlags>Wrap</EditFlags>
            <Maximum>10</Maximum>
            <Increment>0.1</Increment>
            <SortID>3</SortID>
        </Field>
        <Field Def="f32 fMaxDistressAmount = 10,000">
            <DisplayName>乳酸総量[ng]</DisplayName>
            <Description>保持可能な乳酸の最大量[ナノグラム]</Description>
            <DisplayFormat>%.2f</DisplayFormat>
            <EditFlags>Wrap</EditFlags>
            <Maximum>10000</Maximum>
            <Increment>1</Increment>
            <SortID>4</SortID>
        </Field>
        <Field Def="f32 fMinEffectiveDistress">
            <DisplayName>乳酸影響 最低値[ng]</DisplayName>
            <Description>乳酸が攻撃などに影響を及ぼし始める最低量[ナノグラム]
(乳酸がこの値未満なら乳酸の影響を受けない)</Description>
            <DisplayFormat>%.2f</DisplayFormat>
            <EditFlags>Wrap</EditFlags>
            <Maximum>10000</Maximum>
            <Increment>1</Increment>
            <SortID>5</SortID>
        </Field>
        <Field Def="f32 fMaxEffectiveDistress = 10,000">
            <DisplayName>乳酸影響 最大値[ng]</DisplayName>
            <Description>乳酸が与える影響が最大に達する量[ナノグラム]
(乳酸がこの値以上なら乳酸の影響度合いは100%となる)</Description>
            <DisplayFormat>%.2f</DisplayFormat>
            <EditFlags>Wrap</EditFlags>
            <Maximum>10000</Maximum>
            <Increment>1</Increment>
            <SortID>6</SortID>
        </Field>
        <Field Def="f32 fMinBreathlessAnimWait">
            <DisplayName>息切れ 最低ブレンド率</DisplayName>
            <Description>乳酸の影響を受けている際に加算再生する息切れアニメの最低ブレンド率</Description>
            <DisplayFormat>%.2f</DisplayFormat>
            <EditFlags>Wrap</EditFlags>
            <Maximum>1</Maximum>
            <Increment>0.050000001</Increment>
            <SortID>7</SortID>
        </Field>
        <Field Def="f32 fMaxBreathlessAnimWait = 1">
            <DisplayName>息切れ 最大ブレンド率</DisplayName>
            <Description>乳酸の影響を受けている際に加算再生する息切れアニメの最大ブレンド率</Description>
            <DisplayFormat>%.2f</DisplayFormat>
            <EditFlags>Wrap</EditFlags>
            <Maximum>1</Maximum>
            <Increment>0.050000001</Increment>
            <SortID>8</SortID>
        </Field>
        <Field Def="f32 fDecreaseDistressPerSec = 100">
            <DisplayName>乳酸減少量[ng/s]</DisplayName>
            <Description>1秒当たりの乳酸減少量[ナノグラム/秒]</Description>
            <DisplayFormat>%.2f</DisplayFormat>
            <EditFlags>Wrap</EditFlags>
            <Maximum>10000</Maximum>
            <Increment>1</Increment>
            <SortID>9</SortID>
        </Field>
