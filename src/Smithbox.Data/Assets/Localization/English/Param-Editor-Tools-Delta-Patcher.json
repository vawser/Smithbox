      "Key": "PARAM_DeltaPatcher_Checkbox_Display_All",
      "Text": "Display All"
    },
    {
      "Key": "PARAM_DeltaPatcher_Checkbox_Display_All_TT",
      "Text": "If enabled, delta entries for all project types are displayed. Otherwise, only entries for the current project type are displayed."
    },
    {
      "Key": "PARAM_DeltaPatcher_Checkbox_Include_Modified",
      "Text": "Include Modified Rows"
    },
    {
      "Key": "PARAM_DeltaPatcher_Checkbox_Include_Modified_TT",
      "Text": "If enabled, rows considered 'modified' within the delta will be applied. This means the import will modify rows within the primary bank with the same row ID and index as those in the delta."
    },
    {
      "Key": "PARAM_DeltaPatcher_Checkbx_Include_Added",
      "Text": "Include Added Rows"
    },
    {
      "Key": "PARAM_DeltaPatcher_Checkbx_Include_Added_TT",
      "Text": "If enabled, rows considered 'added' within the delta will be applied. This means the import will add these rows to the primary bank."
    },
    {
      "Key": "PARAM_DeltaPatcher_Checkbox_Include_Deleted",
      "Text": "Include Deleted Rows"
    },
    {
      "Key": "PARAM_DeltaPatcher_Checkbox_Include_Deleted_TT",
      "Text": "If enabled, rows considered 'delete' within the delta will be applied. This means the import will delete these rows from the primary bank."
    },
    {
      "Key": "PARAM_DeltaPatcher_Checkbox_Restrict_Modify",
      "Text": "Restrict Row Modification"
    },
    {
      "Key": "PARAM_DeltaPatcher_Checkbox_Restrict_Modify_TT",
      "Text": "If enabled, row modifications will only occur if the row hasn't already been modified."
    },
    {
      "Key": "PARAM_DeltaPatcher_Checkbox_Restrict_Addition",
      "Text": "Restrict Row Addition"
    },
    {
      "Key": "PARAM_DeltaPatcher_Checkbox_Restrict_Addition_TT",
      "Text": "If enabled, row additions will only occur if the row ID doesn't already exist in the primary bank."
    },
    {
      "Key": "PARAM_DeltaPatcher_Checkbox_Allow_Overwrite",
      "Text": "Allow Row Overwrite"
    },
    {
      "Key": "PARAM_DeltaPatcher_Checkbox_Allow_Overwrite_TT",
      "Text": "If enabled, row additions that collide with an existing row ID will overwrite it (rather than being inserted alongside of)."
    },
