    {
      "Key": "PREF_Viewport_Frame_Rate",
      "Text": "Frame Rate"
    },
    {
      "Key": "PREF_Viewport_Frame_Rate_TT",
      "Text": "Adjusts the frame rate of the viewport."
    },
    {
      "Key": "PREF_Viewport_BB_Reject_Unsupported_DXGI_Formats",
      "Text": "Reject Unsupported DXGI Formats during Texture Deswizzle"
    },
    {
      "Key": "PREF_Viewport_BB_Reject_Unsupported_DXGI_Formats_TT",
      "Text": "If enabled, rejects certain DGXI formats when deswizzling PS4 textures."
    },
    {
      "Key": "PREF_Viewport_Enable_Rendering",
      "Text": "Enable Model Rendering"
    },
    {
      "Key": "PREF_Viewport_Enable_Rendering_TT",
      "Text": "If enabled, model rendering will occur within the viewport."
    },
    {
      "Key": "PREF_Viewport_Enable_Texturing",
      "Text": "Enable Texture Rendering"
    },
    {
      "Key": "PREF_Viewport_Enable_Texturing_TT",
      "Text": "If enabled, texture rendering will occur within the viewport."
    },
    {
      "Key": "PREF_Viewport_Enable_Culling",
      "Text": "Enable Frustum Culling"
    },
    {
      "Key": "PREF_Viewport_Enable_Culling_TT",
      "Text": "If enabled, entities outside of the camera frustum to be culled within the viewport."
    },
    {
      "Key": "PREF_Viewport_Limit_Buffer_Indirect_Draw",
      "Text": "Indirect Draw Buffer"
    },
    {
      "Key": "PREF_Viewport_Limit_Buffer_Indirect_Draw_TT",
      "Text": "This value constrains the size of the indirect draw buffer. Exceeding this value will throw an exception."
    },
    {
      "Key": "PREF_Viewport_Limit_Buffer_Flver_Bone",
      "Text": "FLVER Bone Buffer"
    },
    {
      "Key": "PREF_Viewport_Limit_Buffer_Flver_Bone_TT",
      "Text": "This value constrains the size of the FLVER bone buffer. Exceeding this value will throw an exception."
    },
    {
      "Key": "PREF_Viewport_Enable_Model_Masks",
      "Text": "Enable Model Masks"
    },
    {
      "Key": "PREF_Viewport_Enable_Model_Masks_TT",
      "Text": "If enabled, model masks will be accounted for when rendering viewport objects."
    },
    {
      "Key": "PREF_Viewport_Enable_LOD_Facesets",
      "Text": "Enable LOD Facesets"
    },
    {
      "Key": "PREF_Viewport_Enable_LOD_Facesets_TT",
      "Text": "If enabled, render all facesets for all FLVER meshes, including LOD ones."
    },
    {
