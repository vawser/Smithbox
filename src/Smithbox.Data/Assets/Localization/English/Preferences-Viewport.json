    {
      "Key": "PREF_Viewport_Enable_Selection_Outline",
      "Text": "Enable Selection Outline"
    },
    {
      "Key": "PREF_Viewport_Enable_Selection_Outline_TT",
      "Text": "If enabled, a selection outline will display alongside the selection tint on selected viewport objects.\nNote: the outline is error-prone when hundreds (or more) of viewport objects are selected."
    },
    {
      "Key": "PREF_Viewport_Enable_Selection_Tint",
      "Text": "Enable Selection Tint"
    },
    {
      "Key": "PREF_Viewport_Enable_Selection_Tint_TT",
      "Text": "If enabled, selected objects will be tinted."
    },
    {
      "Key": "PREF_Viewport_Enable_Selection_Dithering",
