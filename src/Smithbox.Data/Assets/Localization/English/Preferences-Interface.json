{
  "Entries": [
    {
      "Key": "PREF_Interface_UI_Scale",
      "Text": "Interface Scale"
    },
    {
      "Key": "PREF_Interface_UI_Scale_TT",
      "Text": "Adjusts the scaling of the user interface throughout all of Smithbox."
    },
    {
      "Key": "PREF_Interface_Scale_by_DPI",
      "Text": "Interface Scale affected by DPI"
    },
    {
      "Key": "PREF_Interface_Scale_by_DPI_TT",
      "Text": "Multiplies the user interface scale by your monitor's DPI setting."
    },
    {
      "Key": "PREF_Interface_Font_Size",
      "Text": "Font Size"
    },
    {
      "Key": "PREF_Interface_Font_Size_TT",
      "Text": "Adjusts the size of the font in Smithbox."
    },
    {
      "Key": "PREF_Interface_Alias_Wordwrap_General",
      "Text": "Enable Alias Word-wrap"
    },
    {
      "Key": "PREF_Interface_Alias_Wordwrap_General_TT",
      "Text": "If enabled, aliases will word-wrap if they touch a window's boundry. Otherwise, they will truncate."
    },
    {
      "Key": "PREF_Interface_Alias_Wordwrap_Map_Editor",
      "Text": "Enable Alias Word-wrap (Map Editor)"
    },
    {
      "Key": "PREF_Interface_Alias_Wordwrap_Map_Editor_TT",
      "Text": "If enabled, aliases will word-wrap if they touch a window's boundry. Otherwise, they will truncate. This affects the Map Editor only."
    },
    {
      "Key": "PREF_Interface_Alias_Wordwrap_Model_Editor",
      "Text": "Enable Alias Word-wrap (Model Editor)"
    },
    {
      "Key": "PREF_Interface_Alias_Wordwrap_Model_Editor_TT",
      "Text": "If enabled, aliases will word-wrap if they touch a window's boundry. Otherwise, they will truncate. This affects the Model Editor only."
    },
    {
      "Key": "PREF_Interface_Alias_Wordwrap_Animation_Editor",
      "Text": "Enable Alias Word-wrap (Animation Editor)"
    },
    {
      "Key": "PREF_Interface_Alias_Wordwrap_Animation_Editor_TT",
      "Text": "If enabled, aliases will word-wrap if they touch a window's boundry. Otherwise, they will truncate. This affects the Animation Editor only."
    },
    {
      "Key": "PREF_Interface_Allow_Window_Movement",
      "Text": "Enable Window Movement"
    },
    {
      "Key": "PREF_Interface_Allow_Window_Movement_TT",
      "Text": "If enabled, the internal windows can be moved and docked freely."
    },
